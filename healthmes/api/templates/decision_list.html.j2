{% extends "_base.html.j2" %}
{# Paginated decision index, newest first — the weekly-report entry point
   (docs/PLAN.md §5, §8.5). Context:
   records         DecisionRecord rows for this page
   meta            PageMeta (total_count / limit / offset / has_more)
   kind            active kind filter value or None
   newer_offset    offset for the previous (newer) page or None
   older_offset    offset for the next (older) page or None
   page_href       callable offset -> href preserving limit and kind
   format_created  callable datetime -> display string #}

{% block title %}Decisions — HealthMes{% endblock %}

{% block head %}
<style>
  ul.decision-list { list-style: none; margin: 1rem 0; padding: 0; }
  ul.decision-list li { margin: 0; }
  ul.decision-list a.row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.7rem;
    align-items: baseline;
    padding: 0.65rem 0.8rem;
    border: 1px solid #e7e5e4;
    border-radius: 10px;
    background: #ffffff;
    margin-bottom: 0.5rem;
    color: inherit;
    text-decoration: none;
  }
  ul.decision-list a.row:hover { border-color: #a8a29e; }
  ul.decision-list .when { color: #78716c; font-size: 0.8rem; white-space: nowrap; }
  ul.decision-list .row-summary { flex: 1 1 100%; overflow-wrap: anywhere; }
  @media (min-width: 640px) {
    ul.decision-list .row-summary { flex: 1 1 auto; }
  }
  /* Decision-kind palette (distinct from the node-type palette). */
  .kind-schedule_change { background: #dbeafe; border-color: #93c5fd; color: #1e3a8a; }
  .kind-alert { background: #fee2e2; border-color: #fca5a5; color: #7f1d1d; }
  .kind-insight { background: #fef3c7; border-color: #fcd34d; color: #78350f; }
  .kind-capture { background: #dcfce7; border-color: #86efac; color: #14532d; }
  nav.pager { display: flex; gap: 1rem; align-items: baseline; justify-content: space-between; margin-top: 1rem; }
</style>
{% endblock %}

{% block content %}
<h1>Decision log</h1>
<p class="muted">
  {{ meta.total_count }} decision{{ "s" if meta.total_count != 1 else "" }}
  {% if kind %} · kind: {{ kind }} (<a href="/decisions">clear filter</a>){% endif %}
  · newest first. Every proactive alert links to its entry here.
</p>

{% if records %}
<ul class="decision-list">
  {% for r in records %}
  <li>
    <a class="row" href="/decisions/{{ r.id }}">
      <span class="badge kind-{{ r.kind.value }}">{{ r.kind.value }}</span>
      <span class="when">{{ format_created(r.created_at) }}</span>
      <span class="row-summary">{{ r.summary }}</span>
    </a>
  </li>
  {% endfor %}
</ul>
<nav class="pager">
  <span>
    {% if newer_offset is not none %}<a href="{{ page_href(newer_offset) }}">&larr; Newer</a>{% endif %}
  </span>
  <span class="muted">{{ meta.offset + 1 }}–{{ meta.offset + records | length }} of {{ meta.total_count }}</span>
  <span>
    {% if older_offset is not none %}<a href="{{ page_href(older_offset) }}">Older &rarr;</a>{% endif %}
  </span>
</nav>
{% else %}
<p><em>No decisions recorded yet.</em></p>
{% endif %}
{% endblock %}
