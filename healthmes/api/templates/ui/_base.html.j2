{# HealthMes viewer shell (docs/PLAN.md §5, §8.5) — the shared design system.
   Theme: "건강한 자연, 밝게" — four BRIGHT daylight landscapes (봄 벚꽃 /
   여름 숲 / 가을 단풍 / 겨울 설원), CSS/SVG-generated only (no photos, no
   external assets). Bright-first: the daylight look is served regardless of
   the OS color scheme (no dark variant is shipped). The season is
   auto-picked server-side from the month in the user's timezone
   (shell_context "season") and can be overridden with the header switcher
   (🌸☀️🍂❄️), persisted in localStorage — display-only state.
   Rules: local-first (zero external requests), mobile-first, WCAG-AA
   contrast on the glass cards over all four backdrops, visible focus
   states, prefers-reduced-motion respected (particle drift pauses).
   Performance: backdrop-filter only on the header and .card; particles are
   a handful of GPU-composited transforms.
   Context every page passes (healthmes/api/decision_html.py shell_context):
   token_qs   "?token=<derived viewer token>" or "" — same-origin nav links
              must keep the read-only credential attached (never the API token).
   season     "spring" | "summer" | "autumn" | "winter"
#}
<!DOCTYPE html>
<html lang="ko" data-season="{{ season | default("summer") }}" data-daypart="{{ daypart | default("day") }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="color-scheme" content="light dark">
<meta name="robots" content="noindex">
<title>{% block title %}HealthMes{% endblock %}</title>
<style>
  /* ---- tokens (bright-first: one light theme, tinted per season) -------- */
  :root {
    --bg: #eef4ef;
    --surface: #ffffff;
    --surface-2: rgba(31, 51, 42, 0.07);
    --ink: #1c2823;
    --ink-2: #4e5f57;
    --ink-3: #75847c;
    --line: rgba(31, 51, 42, 0.16);
    --line-soft: rgba(31, 51, 42, 0.1);
    --brand: #12806c;
    --brand-deep: #0b5c4d;
    --brand-soft: rgba(18, 128, 108, 0.14);
    --brand-wash: rgba(18, 128, 108, 0.07);
    --danger: #a63a26;
    --glass: rgba(255, 255, 255, 0.64);
    --glass-solid: rgba(255, 255, 255, 0.8);
    --glass-line: rgba(255, 255, 255, 0.62);
    --shadow: 0 1px 2px rgba(17, 38, 30, 0.06), 0 10px 30px rgba(17, 38, 30, 0.08);
    --radius: 16px;
    --radius-sm: 10px;
    /* scenery defaults = 여름 낮 (deep lush green, clear sky, strong sun).
       Composition scheme: SEASON sets the hue family (--sky-day-*, hills,
       silhouettes, particles, accents); DAYPART sets the actual sky
       (--sky-*), light, glass and ink. 4 x 3 = 12 combos, zero hand-written
       combo palettes. */
    --sky-day-1: #bfe0f6; --sky-day-2: #d9eede; --sky-day-3: #eff7e0;
    --sky-1: var(--sky-day-1); --sky-2: var(--sky-day-2); --sky-3: var(--sky-day-3);
    --dusk-accent: #f5a95f; --night-accent: #0d211a;
    --sun: #fff2c0; --sun-op: 1; --ray-op: 0.09;
    --hill-far: #a9d49b; --hill-mid: #7fbe78; --hill-near: #58a55f;
    --sil: #3e7a4b; --sil-op: 0.28;
    --mist: rgba(255, 255, 255, 0.4);
    --petal: #f6bfce; --fleaf: #d98e3f;
  }
  /* 봄: soft cherry-blossom drift over fresh green hills */
  html[data-season="spring"] {
    --sky-day-1: #cde7f7; --sky-day-2: #e9f4e7; --sky-day-3: #fdeff2;
    --dusk-accent: #f2b3ab; --night-accent: #1d1c33;
    --sun: #fff6de; --sun-op: 0.9; --ray-op: 0.04;
    --hill-far: #d3e8c9; --hill-mid: #b7dcaa; --hill-near: #97cb8e;
    --sil: #b0798f; --sil-op: 0.26;
    --mist: rgba(255, 255, 255, 0.5);
    --glass: rgba(255, 255, 255, 0.66);
  }
  /* 가을: golden foliage, warm light */
  html[data-season="autumn"] {
    --sky-day-1: #d4e4ef; --sky-day-2: #f0e8d1; --sky-day-3: #f8e7c4;
    --dusk-accent: #e29a3d; --night-accent: #221826;
    --sun: #ffe8b3; --sun-op: 0.95; --ray-op: 0.06;
    --hill-far: #e4ca92; --hill-mid: #d8a75e; --hill-near: #bd8747;
    --sil: #8a5a32; --sil-op: 0.3;
    --mist: rgba(255, 250, 238, 0.45);
    --glass: rgba(255, 252, 244, 0.68);
    --glass-solid: rgba(255, 253, 247, 0.84);
  }
  /* 겨울: bright snowfield, crisp pale-blue sky, bare branches */
  html[data-season="winter"] {
    --sky-day-1: #d8e8f3; --sky-day-2: #eaf2f8; --sky-day-3: #fafcfe;
    --dusk-accent: #e6b6d6; --night-accent: #13203a;
    --sun: #ffffff; --sun-op: 0.9; --ray-op: 0.03;
    --hill-far: #e7eef5; --hill-mid: #dbe6ef; --hill-near: #cfdde9;
    --sil: #7e8b96; --sil-op: 0.42;
    --mist: rgba(255, 255, 255, 0.55);
    --glass: rgba(255, 255, 255, 0.72);
    --glass-solid: rgba(255, 255, 255, 0.86);
  }

  /* ---- 시간대 (낮/초저녁/밤) — composed over the season ------------------- */
  /* 초저녁: golden hour. Sky mixes the season's day sky with its dusk
     accent; hills deepen via filters; dark ink stays on warm light glass. */
  html[data-daypart="dusk"] {
    --sky-1: #d9c9c2; --sky-2: #ecc9a6; --sky-3: #f2ba8a; /* color-mix fallback */
    --sky-1: color-mix(in srgb, var(--sky-day-1) 55%, var(--dusk-accent) 45%);
    --sky-2: color-mix(in srgb, var(--sky-day-2) 35%, var(--dusk-accent) 65%);
    --sky-3: color-mix(in srgb, var(--sky-day-3) 22%, var(--dusk-accent) 78%);
    --sun: color-mix(in srgb, var(--dusk-accent) 65%, #ffffff 35%);
    --sun-op: 0.95; --ray-op: 0.05;
    --mist: rgba(255, 240, 224, 0.4);
    --glass: rgba(255, 249, 240, 0.7);
    --glass-solid: rgba(255, 250, 243, 0.88);
  }
  html[data-daypart="dusk"] .scenery .hill-far { filter: brightness(0.92) saturate(1.1) sepia(0.18); }
  html[data-daypart="dusk"] .scenery .hill-mid { filter: brightness(0.86) saturate(1.12) sepia(0.2); }
  html[data-daypart="dusk"] .scenery .hill-near { filter: brightness(0.8) saturate(1.15) sepia(0.22); }
  /* 밤: calm dark. Night sky from the season's night accent; the ONLY dark
     surface set — light ink on dark translucent glass (WCAG-AA checked). */
  html[data-daypart="night"] {
    color-scheme: dark;
    --sky-1: #0a1018; --sky-2: #0d1a19; --sky-3: #0f231c; /* color-mix fallback */
    --sky-1: color-mix(in srgb, var(--night-accent) 45%, #060a10 55%);
    --sky-2: color-mix(in srgb, var(--night-accent) 75%, #081018 25%);
    --sky-3: color-mix(in srgb, var(--night-accent) 62%, #0a150f 38%);
    --sun: #dfe9ef; --sun-op: 0.3; --ray-op: 0;
    --mist: rgba(4, 9, 7, 0.35);
    --ink: #e8efeb; --ink-2: #b0bfb6; --ink-3: #8a998f;
    --line: rgba(232, 239, 235, 0.18); --line-soft: rgba(232, 239, 235, 0.1);
    --surface: #131c17; --surface-2: rgba(255, 255, 255, 0.07);
    --brand: #3fc0a4; --brand-deep: #8adcc8;
    --brand-soft: rgba(76, 196, 168, 0.2); --brand-wash: rgba(76, 196, 168, 0.1);
    --danger: #e79c89;
    --glass: rgba(10, 17, 14, 0.62); --glass-solid: rgba(13, 21, 17, 0.84);
    --glass-line: rgba(255, 255, 255, 0.11);
    --shadow: 0 1px 2px rgba(0, 0, 0, 0.45), 0 12px 34px rgba(0, 0, 0, 0.45);
  }
  html[data-daypart="night"] .scenery .hill-far { filter: brightness(0.34) saturate(0.7); }
  html[data-daypart="night"] .scenery .hill-mid { filter: brightness(0.26) saturate(0.65); }
  html[data-daypart="night"] .scenery .hill-near { filter: brightness(0.2) saturate(0.6); }
  html[data-daypart="night"] .scenery .sil { opacity: calc(var(--sil-op) * 0.5); }
  html[data-daypart="night"] .scenery .petal,
  html[data-daypart="night"] .scenery .fleaf { opacity: 0.45; }
  html[data-daypart="night"] .scenery .snowflake {
    opacity: 1; filter: drop-shadow(0 0 3px rgba(255, 255, 255, 0.85));
  }

  /* ---- base ------------------------------------------------------------ */
  * { box-sizing: border-box; }
  html { -webkit-text-size-adjust: 100%; color-scheme: light; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, system-ui,
      "Apple SD Gothic Neo", "Pretendard", "Noto Sans KR",
      "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    font-size: 15.5px;
    line-height: 1.65;
    color: var(--ink);
    background: var(--bg);
    word-break: keep-all; /* Korean: break between words, not inside them */
  }
  main { display: block; max-width: 62rem; margin: 0 auto; padding: 1.4rem 1.1rem 4rem; }
  h1 {
    font-size: clamp(1.45rem, 4.2vw, 1.85rem);
    font-weight: 750;
    letter-spacing: -0.015em;
    line-height: 1.32;
    margin: 0.35rem 0 0.55rem;
    overflow-wrap: anywhere;
  }
  h2 { font-size: 1.02rem; font-weight: 700; letter-spacing: -0.005em; margin: 0 0 0.65rem; }
  p { margin: 0.4rem 0; }
  a { color: var(--brand-deep); text-decoration: none; }
  a:hover { text-decoration: underline; text-underline-offset: 0.2em; }
  code, .mono {
    font-family: ui-monospace, "SF Mono", SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.86em;
  }
  :focus-visible { outline: 2px solid var(--brand); outline-offset: 2px; border-radius: 4px; }
  ::selection { background: var(--brand-soft); }
  [hidden] { display: none !important; }

  .eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--brand-deep);
    margin: 0;
  }
  .muted { color: var(--ink-2); font-size: 0.86rem; overflow-wrap: anywhere; }
  .subtle { color: var(--ink-3); }
  .error { color: var(--danger); font-size: 0.9rem; }

  .skip {
    position: absolute; left: -999px; top: 0.5rem; z-index: 99;
    background: var(--surface); color: var(--ink);
    padding: 0.45rem 0.9rem; border-radius: 10px; border: 1px solid var(--line);
  }
  .skip:focus { left: 0.5rem; }

  /* ---- scenery (fixed, behind everything, decorative only) -------------- */
  .scenery {
    position: fixed; inset: 0; z-index: -1;
    width: 100%; height: 100%;
    pointer-events: none;
    display: block;
  }
  .scenery .sky-stop-1 { stop-color: var(--sky-1); }
  .scenery .sky-stop-2 { stop-color: var(--sky-2); }
  .scenery .sky-stop-3 { stop-color: var(--sky-3); }
  .scenery .sun-core { stop-color: var(--sun); stop-opacity: var(--sun-op); }
  .scenery .sun-edge { stop-color: var(--sun); stop-opacity: 0; }
  .scenery .ray { fill: var(--sun); opacity: var(--ray-op); }
  .scenery .hill-far { fill: var(--hill-far); }
  .scenery .hill-mid { fill: var(--hill-mid); }
  .scenery .hill-near { fill: var(--hill-near); }
  .scenery .mist { fill: var(--mist); }
  .scenery .sil { fill: var(--sil); opacity: var(--sil-op); }
  /* seasonal particles: hidden unless their season is active */
  .scenery .petals, .scenery .fall-leaves, .scenery .snow { display: none; }
  html[data-season="spring"] .scenery .petals { display: block; }
  html[data-season="autumn"] .scenery .fall-leaves { display: block; }
  html[data-season="winter"] .scenery .snow { display: block; }
  .scenery .petal { fill: var(--petal); opacity: 0.75; }
  .scenery .fleaf { fill: var(--fleaf); opacity: 0.8; }
  .scenery .snowflake { fill: #ffffff; opacity: 0.9; }
  /* night-only layers: stars + moon everywhere, fireflies on summer nights */
  .scenery .stars, .scenery .moon, .scenery .fireflies { display: none; }
  html[data-daypart="night"] .scenery .stars { display: block; }
  html[data-daypart="night"] .scenery .moon { display: block; }
  html[data-season="summer"][data-daypart="night"] .scenery .fireflies { display: block; }
  .scenery .star { fill: #e9f2f7; opacity: 0.75; }
  .scenery .moon-glow { fill: #dfe9ef; opacity: 0.16; }
  .scenery .moon-disc { fill: #e9f1ec; opacity: 0.95; }
  .scenery .fly {
    fill: #ffe9a0; opacity: 0.9;
    filter: drop-shadow(0 0 4px rgba(255, 233, 160, 0.9));
  }
  @media (prefers-reduced-motion: no-preference) {
    @keyframes drift-fall {
      0% { transform: translate(0, -140px) rotate(0deg); opacity: 0; }
      10% { opacity: 0.85; }
      100% { transform: translate(52px, 880px) rotate(310deg); opacity: 0.55; }
    }
    @keyframes snow-fall {
      0% { transform: translate(0, -100px); opacity: 0; }
      12% { opacity: 0.95; }
      100% { transform: translate(-36px, 920px); opacity: 0.75; }
    }
    .scenery .petal, .scenery .fleaf { animation: drift-fall 14s linear infinite; }
    .scenery .snowflake { animation: snow-fall 12s linear infinite; }
    .scenery .pt g:nth-of-type(2n) > * { animation-delay: -4.5s; animation-duration: 17s; }
    .scenery .pt g:nth-of-type(3n) > * { animation-delay: -9s; animation-duration: 15s; }
    .scenery .pt g:nth-of-type(4n) > * { animation-delay: -12s; animation-duration: 19s; }
    .scenery .pt g:nth-of-type(5n) > * { animation-delay: -2.5s; }
    @keyframes twinkle { from { opacity: 0.2; } to { opacity: 0.85; } }
    .scenery .star { animation: twinkle 2.8s ease-in-out infinite alternate; }
    .scenery .stars g:nth-of-type(2n) .star { animation-delay: 1.1s; animation-duration: 3.6s; }
    .scenery .stars g:nth-of-type(3n) .star { animation-delay: 2s; }
    @keyframes fly-drift {
      0% { transform: translate(0, 0); opacity: 0.2; }
      50% { transform: translate(10px, -16px); opacity: 0.95; }
      100% { transform: translate(-8px, -30px); opacity: 0.15; }
    }
    .scenery .fly { animation: fly-drift 7s ease-in-out infinite alternate; }
    .scenery .fireflies g:nth-of-type(2n) .fly { animation-duration: 9s; animation-delay: 1.6s; }
    .scenery .fireflies g:nth-of-type(3n) .fly { animation-duration: 11s; animation-delay: 3.1s; }
  }

  /* ---- site chrome ------------------------------------------------------ */
  header.site {
    position: sticky; top: 0; z-index: 20;
    background: var(--glass-solid);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
    backdrop-filter: blur(12px) saturate(140%);
    border-bottom: 1px solid var(--glass-line);
  }
  .site-inner {
    max-width: 62rem; margin: 0 auto; padding: 0.6rem 1.1rem;
    display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap;
  }
  a.brand {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-weight: 800; font-size: 1.02rem; letter-spacing: -0.01em;
    color: var(--ink);
  }
  a.brand:hover { text-decoration: none; }
  .brand-dot {
    width: 0.62rem; height: 0.62rem; border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, var(--brand), var(--brand-deep));
    box-shadow: 0 0 0 3px var(--brand-soft);
  }
  .crumb { color: var(--ink-3); font-weight: 400; font-size: 0.9rem; }
  nav.site-nav { margin-left: auto; display: flex; gap: 0.2rem; }
  nav.site-nav a {
    color: var(--ink-2); font-size: 0.88rem; font-weight: 600;
    padding: 0.3rem 0.7rem; border-radius: 999px;
  }
  nav.site-nav a:hover { background: var(--surface-2); color: var(--ink); text-decoration: none; }
  nav.site-nav a[aria-current="page"] { background: var(--brand-soft); color: var(--brand-deep); }
  .season-picker {
    display: inline-flex; align-items: center; gap: 2px;
    background: var(--surface-2); border: 1px solid var(--line-soft);
    border-radius: 999px; padding: 2px;
  }
  .season-picker button {
    border: 0; background: transparent; cursor: pointer;
    font-size: 0.95rem; line-height: 1; padding: 0.22rem 0.45rem;
    border-radius: 999px;
  }
  .season-picker button[aria-pressed="true"] {
    background: var(--glass-solid); box-shadow: var(--shadow);
  }
  .ambience { display: flex; align-items: center; gap: 0.35rem; flex-wrap: wrap; }
  @media (max-width: 480px) {
    .season-picker button { font-size: 0.82rem; padding: 0.16rem 0.3rem; }
  }

  footer.site-foot {
    max-width: 62rem; margin: 0 auto; padding: 0 1.1rem 2.2rem;
    color: var(--ink-2); font-size: 0.8rem;
  }

  /* ---- glass components -------------------------------------------------- */
  .card {
    background: var(--glass);
    -webkit-backdrop-filter: blur(16px) saturate(150%);
    backdrop-filter: blur(16px) saturate(150%);
    border: 1px solid var(--glass-line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.05rem 1.15rem 1.15rem;
    margin: 0.9rem 0;
  }
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .card { background: var(--surface); }
    header.site { background: var(--surface); }
  }
  .card > h2 { display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: wrap; }
  .card > h2 code.k { color: var(--ink-3); font-weight: 500; font-size: 0.72rem; }

  .badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    border-radius: 999px;
    padding: 0.1rem 0.6rem;
    border: 1px solid var(--line);
    background: var(--glass-solid);
    color: var(--ink-2);
    vertical-align: middle;
    white-space: nowrap;
  }
  /* Node-type palette — keep hues in sync with _CLASS_DEFS in decision_html.py. */
  .type-input    { background: #e3ecfb; border-color: #c7d9f5; color: #2b4d87; }
  .type-rule     { background: #ebe6fa; border-color: #d6cbf2; color: #55389b; }
  .type-llm_step { background: #f9efd4; border-color: #eedfae; color: #7c5a14; }
  .type-option   { background: #d9f2ed; border-color: #b7e4db; color: #146055; }
  .type-action   { background: #def2dd; border-color: #c2e5c0; color: #2b6532; }
  .type-other    { background: #edf0ee; border-color: #d9dfdb; color: #4e5b55; }
  /* Decision-kind palette (proposal/feedback framing). */
  .kind-schedule_change { background: #e3ecfb; border-color: #c7d9f5; color: #2b4d87; }
  .kind-alert           { background: #fbe4df; border-color: #f4ccc3; color: #96351f; }
  .kind-insight         { background: #f9efd4; border-color: #eedfae; color: #7c5a14; }
  .kind-capture         { background: #def2dd; border-color: #c2e5c0; color: #2b6532; }

  .btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    border: 1px solid var(--line); background: var(--glass-solid); color: var(--ink);
    border-radius: 10px; padding: 0.38rem 0.85rem;
    font: inherit; font-size: 0.85rem; font-weight: 600; cursor: pointer;
  }
  .btn:hover { border-color: var(--brand); }
  .seg {
    display: inline-flex; align-items: center; gap: 2px;
    background: var(--surface-2); border: 1px solid var(--line-soft);
    border-radius: 999px; padding: 3px;
  }
  .seg button {
    border: 0; background: transparent; color: var(--ink-2); cursor: pointer;
    font: inherit; font-size: 0.85rem; font-weight: 600;
    padding: 0.32rem 0.9rem; border-radius: 999px;
  }
  .seg button[aria-pressed="true"] {
    background: var(--glass-solid); color: var(--ink); box-shadow: var(--shadow);
  }

  /* Proposal rows (list page + weekly report): summary sentence leads. */
  ul.decision-list { list-style: none; margin: 0.9rem 0 0; padding: 0; }
  ul.decision-list li { margin: 0 0 0.55rem; }
  ul.decision-list a.row {
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.3rem 0.7rem;
    padding: 0.85rem 1rem;
    background: var(--glass-solid); border: 1px solid var(--glass-line);
    border-radius: 12px; color: inherit; text-decoration: none;
    transition: border-color 120ms ease, box-shadow 120ms ease;
  }
  ul.decision-list a.row:hover {
    border-color: var(--brand); box-shadow: var(--shadow); text-decoration: none;
  }
  ul.decision-list .row-summary {
    flex: 1 1 100%; overflow-wrap: anywhere; line-height: 1.55; font-weight: 600;
  }
  ul.decision-list .row-meta {
    display: inline-flex; align-items: baseline; gap: 0.55rem; flex-wrap: wrap;
  }
  ul.decision-list .when { color: var(--ink-3); font-size: 0.78rem; white-space: nowrap; }
  ul.decision-list .row-go { margin-left: auto; color: var(--ink-3); font-weight: 700; }

  /* Stat tiles + tables (weekly report). */
  .stats {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(7.2rem, 1fr));
    gap: 0.6rem; margin: 0.5rem 0 0.3rem;
  }
  .stat {
    background: var(--surface-2); border: 1px solid var(--line-soft);
    border-radius: 12px; padding: 0.7rem 0.85rem;
  }
  .stat .value {
    display: block; font-size: 1.5rem; font-weight: 750; letter-spacing: -0.01em;
    line-height: 1.25;
  }
  .stat .label { font-size: 0.73rem; font-weight: 600; color: var(--ink-2); }
  table.plain { border-collapse: collapse; width: 100%; font-size: 0.88rem; margin-top: 0.5rem; }
  table.plain th, table.plain td {
    text-align: left; padding: 0.38rem 0.5rem; border-bottom: 1px solid var(--line-soft);
  }
  table.plain tr:last-child td { border-bottom: none; }
  table.plain th {
    color: var(--ink-3); font-weight: 650; font-size: 0.71rem;
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  table.plain .num { text-align: right; font-variant-numeric: tabular-nums; }

  nav.pager {
    display: flex; gap: 1rem; align-items: baseline; justify-content: space-between;
    margin-top: 1.1rem; font-size: 0.9rem;
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation: none !important; transition: none !important; }
  }
  @media print {
    header.site, footer.site-foot, .scenery, .no-print { display: none !important; }
    body { background: #ffffff; }
    .card { background: #ffffff; }
  }
</style>
