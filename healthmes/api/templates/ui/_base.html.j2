  HealthMes · 모든 건강 데이터는 이 기기에만 머뭅니다 — local-first, no cloud.
</footer>
<script>
(function () {
  "use strict";
  /* Ambience switchers (season + time-of-day). The server pre-picks both
     from the user's local clock; a manual choice wins and persists in
     localStorage; with no manual choice the daypart is re-evaluated from
     the browser clock on load so a long-lived tab never goes stale.
     Display-only state — nothing but the season/daypart name is stored. */
  var root = document.documentElement;
  function initPicker(name, storageKey, valid, autoValue) {
    var picker = document.querySelector("[data-" + name + "-picker]");
    if (!picker) { return; }
    var saved = null;
    try { saved = window.localStorage.getItem(storageKey); } catch (err) { saved = null; }
    if (saved && valid[saved]) {
      root.setAttribute("data-" + name, saved);
    } else if (autoValue && valid[autoValue]) {
      root.setAttribute("data-" + name, autoValue);
    }
    var buttons = picker.querySelectorAll("button[data-" + name + "-choice]");
    function sync() {
      var current = root.getAttribute("data-" + name);
      buttons.forEach(function (button) {
        var mine = button.getAttribute("data-" + name + "-choice") === current;
        button.setAttribute("aria-pressed", String(mine));
      });
    }
    buttons.forEach(function (button) {
      button.addEventListener("click", function () {
        var choice = button.getAttribute("data-" + name + "-choice");
        if (!valid[choice]) { return; }
        root.setAttribute("data-" + name, choice);
        try { window.localStorage.setItem(storageKey, choice); } catch (err) { }
        sync();
      });
    });
    picker.hidden = false;
    sync();
  }
  initPicker("season", "healthmes-season",
    { spring: 1, summer: 1, autumn: 1, winter: 1 }, null);
  var hour = new Date().getHours();
  var clockDaypart = (hour >= 6 && hour < 17) ? "day" : (hour >= 17 && hour < 20) ? "dusk" : "night";
  initPicker("daypart", "healthmes-daypart",
    { day: 1, dusk: 1, night: 1 }, clockDaypart);
})();
</script>
