# Environment for the open-wearables backend/worker (repo-root copy so
# vendor/ stays untouched).
#
#   install -m 600 config/open-wearables.env.example config/open-wearables.env
#
# Consumed by BOTH run paths:
#   - mac-native: scripts/dev_mac.sh `ow` / `ow-worker` source-exports this
#     file before booting vendor/open-wearables/backend (process env beats
#     the vendored config/.env in pydantic-settings).
#   - docker compose: env_file of the ow-backend / ow-worker services;
#     compose overrides DB_HOST/REDIS_HOST with the service names.
# Because of the dual consumers, keep values shell-safe (JSON values in
# single quotes) and keep localhost defaults here — docker values are
# injected by docker-compose.yml, never hardcoded in this file.
#
# This is the minimal subset needed to boot; the full reference (all provider
# OAuth credentials, S3, Sentry, Svix, ...) is
# vendor/open-wearables/backend/config/.env.example — any variable from there
# can be added here.

#--- APP ---#
ENVIRONMENT="local"
API_PORT=8000
CORS_ORIGINS='["http://localhost:3000"]'
FRONTEND_URL=http://localhost:3000

#--- DB ---#
DB_HOST=localhost
DB_PORT=5432
DB_NAME=open-wearables
DB_USER=open-wearables
DB_PASSWORD=open-wearables

#--- REDIS ---#
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_SSL=false

#--- SENTRY ---#
SENTRY_ENABLED=False
SENTRY_DSN=""

#--- AUTH ---#
# python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-secret-key

#--- ADMIN SEED ---#
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=change-me-admin-password

#--- EMAIL (Resend) ---#
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM_ADDRESS="onboarding@resend.dev"
EMAIL_FROM_NAME="Open Wearables"

#--- SYNC SETTINGS ---#
SYNC_INTERVAL_SECONDS=3600
SLEEP_SCORE_INTERVAL_SECONDS=600
RESILIENCE_SCORE_INTERVAL_SECONDS=600
HISTORICAL_SYNC_ON_CONNECT=true
INGEST_WORKOUT_SAMPLES=false
STORE_FIT_FILES=false

#--- OUTGOING WEBHOOKS (Svix) ---#
# No svix-server runs in this stack (either path); registration failures are
# retried and non-fatal (see vendor backend scripts/start/app.sh).
SVIX_SERVER_URL=http://localhost:8071

#--- Providers ---#
# Public base URL of the API (used for OAuth redirect URIs, etc.)
API_BASE_URL=http://localhost:8000

# Oura Cloud OAuth app (https://cloud.ouraring.com/oauth/applications)
# Register this redirect URI exactly:
#   http://localhost:8000/api/v1/oauth/oura/callback
# Keep the real secret only in config/open-wearables.env (gitignored).
OURA_CLIENT_ID=your-oura-client-id
OURA_CLIENT_SECRET=your-oura-client-secret
# `daily` covers daily sleep, activity, and readiness summaries. The app used
# for the 2026-07-12 dogfood did not expose the vendored backend's separate
# legacy `activity` scope.
OURA_DEFAULT_SCOPE="personal daily heartrate workout session spo2 ring_configuration heart_health"

# Add provider credentials from vendor/open-wearables/backend/config/.env.example
# as needed (SUUNTO_*, POLAR_*, GARMIN_*, WHOOP_*, OURA_*, STRAVA_*, FITBIT_*,
# ULTRAHUMAN_*).
