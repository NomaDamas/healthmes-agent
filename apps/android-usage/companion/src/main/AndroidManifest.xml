<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Fetch the glance briefing from the user's own HealthMes instance. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- API 33+: local alert notifications (PLAN.md §8.5 grammar) need this
         runtime permission; the pairing screen requests it. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.HealthMesCompanion"
        android:usesCleartextTraffic="true"
        tools:ignore="UsesCleartextTraffic">
        <!-- Cleartext HTTP stays enabled because the typical pairing target is
             a HealthMes instance on the same LAN (http://192.168.x.x:8100),
             matching the :app collector. -->

        <activity
            android:name=".PairingActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Home-screen (and, on Android 15+, lock-screen-capable) briefing
             widget backed by Glance. -->
        <receiver
            android:name=".widget.BriefingWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/briefing_widget_info" />
        </receiver>

        <!-- Stub handler for the §8.5 notification action buttons. -->
        <receiver
            android:name=".notify.NotificationActionReceiver"
            android:exported="false" />
    </application>

</manifest>
