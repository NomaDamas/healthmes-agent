        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장 후 홈/잠금화면 위젯 갤러리에서 HealthMes 위젯을 추가하세요. 워치가 페어링되어 있으면 워치 앱에 자동으로 동기화됩니다."
          }
        }
      }
    },
