# HealthMes Agent environment (cp .env.example .env).
#
# Two consumers:
#   1. healthmes/config.py reads every HEALTHMES_* variable (env prefix).
#   2. docker-compose.yml interpolates the un-prefixed variables below.
# Defaults here (and in healthmes/config.py) target mac-native localhost
# development; inside containers docker-compose.yml overrides the in-cluster
# endpoints (database/ow/hermes URLs), so this file never needs docker
# service hostnames.

# ─── healthmes service (HEALTHMES_ prefix) ──────────────────────────────────
# SQLAlchemy URL of the dedicated healthmes database. Default: zero-setup
# repo-local sqlite. For the postgres-backed native run (after `make
# mac-setup` + `make mac-services-start`) uncomment the second line.
HEALTHMES_DATABASE_URL=sqlite:///./data/healthmes.db
#HEALTHMES_DATABASE_URL=postgresql+psycopg://healthmes:healthmes@localhost:5432/healthmes
# (docker compose sets: postgresql+psycopg://healthmes:healthmes@postgres:5432/healthmes)

# open-wearables backend REST API (read-only consumer).
HEALTHMES_OW_BASE_URL=http://localhost:8000
# (docker compose sets: http://ow-backend:8000)

# API key issued in the open-wearables developer portal (same key the vendor
# MCP server uses).
HEALTHMES_OW_API_KEY=

# UUID of the single open-wearables user this deployment reads. Optional:
# when empty, tools auto-discover via GET /api/v1/users (works only when the
# API key sees exactly one user).
HEALTHMES_OW_USER_ID=

# Hermes gateway webhook route for proactive alerts. 8644 is the vendor
# gateway's DEFAULT_PORT (gateway/platforms/webhook.py); route name
# 'healthmes-alerts' comes from config/hermes-config.yaml.tmpl.
HEALTHMES_HERMES_WEBHOOK_URL=http://localhost:8644/webhooks/healthmes-alerts
# (docker compose sets: http://hermes:8644/webhooks/healthmes-alerts)

# HMAC secret shared with the Hermes webhook route (config/hermes-config.yaml.tmpl).
HEALTHMES_HERMES_WEBHOOK_SECRET=

# Externally reachable base URL of the healthmes service — used to build the
# decision-viewer links embedded in Telegram alerts. Keep it host-reachable
# (your phone's browser opens it), not a docker service name.
HEALTHMES_PUBLIC_BASE_URL=http://localhost:8100

# Local-first data directory (media files, sqlite db, exports, pidfiles).
HEALTHMES_DATA_DIR=./data
# (docker compose sets: /data — a named volume)

# Service port.
HEALTHMES_PORT=8100

# Interface the service binds. The localhost default keeps the surface
# (medical records, health context, /mcp) off the network. Set 0.0.0.0 to
# accept LAN clients (the Android usage collector) — the service then refuses
# to start unless HEALTHMES_API_TOKEN is set. docker compose always runs with
# 0.0.0.0 inside the container, so the token is REQUIRED for compose.
HEALTHMES_HOST=127.0.0.1

# Bearer token protecting the whole HTTP surface (REST + /mcp). Every client
# sends 'Authorization: Bearer <token>' (the Android collector's token field,
# Hermes' healthmes MCP registration, curl). Decision-viewer links embed a
# derived read-only token automatically. Generate one with e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
HEALTHMES_API_TOKEN=

# Enable in-process APScheduler loops (10-min trigger sweep, hourly
# cognitive-energy persist, weekly backup).
HEALTHMES_SCHEDULER_ENABLED=false

# IANA timezone of the user (e.g. Asia/Seoul) — local-day boundaries and the
# calendar/app-usage joins in the MCP tools use it. Leave unset on mac-native
# (machine timezone wins); set it when running in docker, where container
# clocks are UTC (docker-compose.yml forwards it to the healthmes service).
#HEALTHMES_TIMEZONE=Asia/Seoul

# Alert hygiene (docs/PLAN.md §11): do-not-disturb window, per-day push
# budget, and per-rule cooldown enforced before any proactive webhook push.
HEALTHMES_QUIET_HOURS_START=22:30
HEALTHMES_QUIET_HOURS_END=07:00
HEALTHMES_ALERT_DAILY_BUDGET=8
HEALTHMES_ALERT_COOLDOWN_MINUTES=60

# Calendar mirror backends (docs/PLAN.md §6) — both OFF by default because
# they need real credentials.
# Google: put the OAuth client secret at {HEALTHMES_DATA_DIR}/google/
# client_secret.json and run the interactive bootstrap once to mint
# {HEALTHMES_DATA_DIR}/google/calendar_token.json.
HEALTHMES_GOOGLE_CALENDAR_ENABLED=false
HEALTHMES_GOOGLE_CALENDAR_ID=primary
HEALTHMES_GOOGLE_POLL_MINUTES=5
# iCloud CalDAV: username = Apple ID email, password = app-specific password
# minted at https://appleid.apple.com (never the account password).
HEALTHMES_CALDAV_ENABLED=false
HEALTHMES_CALDAV_URL=https://caldav.icloud.com
HEALTHMES_CALDAV_USERNAME=
HEALTHMES_CALDAV_APP_PASSWORD=
#HEALTHMES_CALDAV_CALENDAR_NAME=
HEALTHMES_CALDAV_POLL_MINUTES=10

# Local-first encrypted backups (docs/BACKUP.md; `healthmes backup create/
# list/restore` + the weekly scheduler job). Snapshots are age-encrypted with
# this passphrase — without it, `backup create` errors and the weekly job
# skips with a warning. LOSING THE PASSPHRASE MEANS LOSING THE BACKUPS.
HEALTHMES_BACKUP_PASSPHRASE=
# Snapshot directory (default: {HEALTHMES_DATA_DIR}/backups).
#HEALTHMES_BACKUP_DIR=./data/backups
# Direct postgres URL of the open-wearables DB — only needed to include its
# pg_dump in snapshots (the REST URL above cannot produce a dump).
#HEALTHMES_OW_DATABASE_URL=postgresql://open-wearables:open-wearables@localhost:5432/open-wearables
# Hermes state (memory, cron jobs) is included when HEALTHMES_HERMES_HOME is
# set — or via the vendor's own HERMES_HOME env var (native default ~/.hermes,
# compose ./data/hermes).
#HEALTHMES_HERMES_HOME=

# Remote vault replication (docs/BACKUP.md §3): mirror the age-encrypted
# snapshot envelopes to any S3-compatible bucket (AWS S3 / Cloudflare R2 /
# MinIO). The vault only ever sees ciphertext — snapshots are encrypted
# client-side before upload, and the provider refuses to upload anything
# that is not an age envelope. Selector: 'local' (default) or 'remote_vault'
# (keeps the local snapshot AND replicates; the weekly job follows it too).
# Per-command override: `healthmes backup create --provider remote`.
#HEALTHMES_BACKUP_PROVIDER=remote_vault
# Endpoint URL for R2/MinIO; leave unset for AWS S3 proper.
#HEALTHMES_VAULT_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#HEALTHMES_VAULT_BUCKET=my-healthmes-vault
#HEALTHMES_VAULT_ACCESS_KEY_ID=
#HEALTHMES_VAULT_SECRET_ACCESS_KEY=
# Region: 'auto' for R2, a real region for AWS/MinIO.
#HEALTHMES_VAULT_REGION=auto
# Key prefix inside the bucket (default: healthmes-vault).
#HEALTHMES_VAULT_PREFIX=healthmes-vault

# ─── docker compose interpolation ───────────────────────────────────────────
# Host port mappings (defaults shown; HEALTHMES_PORT above is reused for the
# healthmes service mapping).
#DB_PORT=5432
#REDIS_PORT=6379
#API_PORT=8000
#OW_MCP_PORT=8200
#HERMES_WEBHOOK_PORT=8644

# open-wearables API key for the ow-mcp service.
OPEN_WEARABLES_API_KEY=

# Hermes gateway (vendor/hermes-agent/.env.example has the full catalog).
TELEGRAM_BOT_TOKEN=
ANTHROPIC_API_KEY=

# LLM selection (optional — omit both to use the vendor default: Anthropic
# Claude). Any plugin under vendor/hermes-agent/plugins/model-providers/
# works: anthropic, openai-codex, gemini, openrouter, ollama-cloud, bedrock,
# vertex, deepseek, xai, … Set the matching provider's API key env var
# (e.g. OPENAI_API_KEY, GEMINI_API_KEY, OPENROUTER_API_KEY) alongside.
# Rendered into the config's root `model:` section by bootstrap; the same
# selection drives both the gateway and `hermes chat`.
#HERMES_MODEL=
#HERMES_PROVIDER=
# For OpenAI-compatible endpoints (OpenAI itself, Ollama, vLLM) via the
# `custom` provider: set the base URL and the key below.
#   OpenAI:  HERMES_PROVIDER=custom  HERMES_MODEL=gpt-5.4
#            HERMES_MODEL_BASE_URL=https://api.openai.com/v1
#            HERMES_MODEL_API_KEY=sk-...
#   Grok:    HERMES_PROVIDER=xai     HERMES_MODEL=grok-4        + XAI_API_KEY
#   Gemini:  HERMES_PROVIDER=gemini  HERMES_MODEL=gemini-3-pro  + GEMINI_API_KEY
#HERMES_MODEL_BASE_URL=
#HERMES_MODEL_API_KEY=
# Host uid/gid owning ./data/hermes (defaults to 10000; set to $(id -u)/$(id -g)).
#HERMES_UID=
#HERMES_GID=

# ─── scripts/bootstrap.py (hermes config render) ────────────────────────────
# Default Telegram delivery target for cron briefings and webhook alerts
# (rendered as platforms.telegram.home_channel + the alert route's
# deliver_extra.chat_id). The bootstrap script itself runs fine without it,
# BUT until it is set — or you send /sethome to the bot in your Telegram
# chat — every `deliver: telegram` send (cron briefing, webhook alert) fails
# with "No chat_id or home channel" (vendor gateway/platforms/webhook.py).
# @userinfobot tells you your chat id.
#TELEGRAM_HOME_CHAT_ID=
#TELEGRAM_HOME_CHAT_NAME=Home
# Comma-separated Telegram user-id allowlist rendered into
# platforms.telegram.extra.allow_from (default: everyone).
#TELEGRAM_ALLOWED_USER_IDS=
